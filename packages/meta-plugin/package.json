{
  "name": "@rcd/meta-plugin",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./babel": {
      "types": "./dist/babel.d.ts",
      "import": "./dist/babel.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/babel.ts --format esm --dts --clean",
    "dev": "tsup src/index.ts src/babel.ts --format esm --dts --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@rcd/protocol": "workspace:*"
  },
  "peerDependencies": {
    "@babel/core": "^7.24.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@babel/types": "^7.29.0",
    "@types/babel__core": "^7.20.5",
    "tsup": "^8.3.0",
    "typescript": "^5.6.3"
  }
}
