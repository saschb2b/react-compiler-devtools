{
  "name": "@rcd/runtime",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./shim": {
      "types": "./dist/shim.d.ts",
      "import": "./dist/shim.js"
    },
    "./bootstrap": {
      "types": "./dist/bootstrap.d.ts",
      "import": "./dist/bootstrap.js"
    },
    "./bridge": {
      "types": "./dist/bridge.d.ts",
      "import": "./dist/bridge.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/shim.ts src/bootstrap.ts src/bridge.ts --format esm --dts --clean",
    "dev": "tsup src/index.ts src/shim.ts src/bootstrap.ts src/bridge.ts --format esm --dts --watch",
    "typecheck": "tsc --noEmit",
    "test": "node test-smoke.mjs"
  },
  "dependencies": {
    "@rcd/protocol": "workspace:*"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "devDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.3"
  }
}
