{
  "name": "@rcd/next-plugin",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./loader": {
      "types": "./dist/loader.d.ts",
      "import": "./dist/loader.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/loader.ts --format esm --dts --clean",
    "dev": "tsup src/index.ts src/loader.ts --format esm --dts --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@babel/core": "^7.25.0",
    "@rcd/babel-preset": "workspace:*",
    "@rcd/meta-plugin": "workspace:*",
    "@rcd/protocol": "workspace:*"
  },
  "peerDependencies": {
    "next": "^15.0.0"
  },
  "devDependencies": {
    "@types/babel__core": "^7.20.5",
    "next": "^15.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.3"
  }
}
