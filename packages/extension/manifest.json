{
  "manifest_version": 3,
  "name": "React Compiler DevTools",
  "version": "0.1.0",
  "description": "See what the React Compiler optimized, what it skipped and why, and watch cache hit/miss live.",
  "minimum_chrome_version": "120",
  "devtools_page": "devtools.html",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": false
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["bridge.js"],
      "matches": ["<all_urls>"]
    }
  ],
  "permissions": ["scripting"],
  "host_permissions": ["<all_urls>"]
}
